{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracklist Link",
  "version": "0.2.0",
  "identifier": "gg.blackpearl.tracklist-link",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../frontend",
    "beforeBuildCommand": "npm run build --prefix ../../frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tracklist Link",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0b0d14"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "category": "Utility",
    "shortDescription": "Local audio companion for Tracklist",
    "longDescription": "Captures system audio on Windows via WASAPI loopback and serves real-time FFT spectra to audio-reactive overlays and visualizers.",
    "resources": [],
    "icon": []
  }
}
