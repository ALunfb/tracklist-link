{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracklist Link",
  "version": "0.4.0",
  "identifier": "gg.blackpearl.tracklist-link",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../frontend",
    "beforeBuildCommand": "npm run build --prefix ../../frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tracklist Link",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0b0d14"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-eval' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "connect-src": "'self' ipc: http://ipc.localhost http://tauri.localhost https:",
        "img-src": "'self' data: blob: https:",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "category": "Utility",
    "shortDescription": "Local audio companion for Tracklist",
    "longDescription": "Captures system audio on Windows via WASAPI loopback and serves real-time FFT spectra to audio-reactive overlays and visualizers.",
    "resources": [],
    "icon": []
  }
}
